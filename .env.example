# Database (required)
DATABASE_URL=postgresql://postgres:root@localhost:5432/graphql-poc?schema=public

# JWT (required for login flow). Use a strong secret in production.
JWT_SECRET=your-jwt-secret-change-in-production

# Auth (optional): set to require Bearer token on mutations
# If unset, all operations are allowed (useful for local testing).
# AUTH_API_KEY=your-secret-key
